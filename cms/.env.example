# cms — 方案 B：公网经 admin.orasage.com/cms 访问，API 拉取走内网
NODE_ENV=production
PORT=3120
DATABASE_URL=postgresql://orasage:change-me@127.0.0.1:5432/orasage_cms
PAYLOAD_SECRET=change-me-to-a-random-string-at-least-32-chars
# 与 auth-service / admin / shop 共用（CMS JWT SSO）
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token
NEXT_PUBLIC_AUTH_URL=https://auth.orasage.com
NEXT_PUBLIC_ADMIN_URL=https://admin.orasage.com
CMS_BASE_PATH=/cms
NEXT_PUBLIC_SERVER_URL=https://admin.orasage.com/cms
# 媒体文件持久化目录（勿放在 git 工作区内，避免 deploy 时被清理）
CMS_MEDIA_DIR=/var/lib/orasage/cms-media
