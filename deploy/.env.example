# OraSage 方案 B — 共享环境变量模板
# 复制到各 App 的 .env，按实际修改

# ── 认证（所有 App 必须一致） ────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token
JWT_COOKIE_DOMAIN=.orasage.com

# ── 公网 URL（各 App 按自身修改） ────────────────────────────
# main
APP_URL=https://orasage.com

# auth
AUTH_URL=https://auth.orasage.com
AUTH_INTERNAL_URL=http://127.0.0.1:3101

# shop
SHOP_URL=https://shop.orasage.com
SHOP_INTERNAL_URL=http://127.0.0.1:3102

# bazi
BAZI_URL=https://bazi.orasage.com
BAZI_INTERNAL_URL=http://127.0.0.1:3110

# ziwei
ZIWEI_URL=https://ziwei.orasage.com
ZIWEI_INTERNAL_URL=http://127.0.0.1:3111

# tarot
TAROT_URL=https://tarot.orasage.com
TAROT_INTERNAL_URL=http://127.0.0.1:3112

# cms
CMS_URL=https://cms.orasage.com
CMS_INTERNAL_URL=http://127.0.0.1:3120

# admin
ADMIN_URL=https://admin.orasage.com

# ── 数据库 ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/orasage_auth
REDIS_URL=redis://127.0.0.1:6379

# ── Stripe（shop 专用） ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── 开发环境覆盖 ─────────────────────────────────────────────
# NODE_ENV=development
# JWT_COOKIE_DOMAIN=.orasage.localhost
# AUTH_URL=http://auth.orasage.localhost:3101
