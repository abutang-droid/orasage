# OriCosmos 并行环境 — 共享环境变量模板
# 用途：新 Google VM（oricosmos.com），与 orasage.com 生产并存
# 复制到 /opt/orasage/.env，并同步到各 App 的 .env（JWT / URL 必须一致）

# ── 站点 apex（构建导航 / 跨域链接用；deploy 脚本会按 NGINX_SITE 写入）──
SITE_APEX=oricosmos.com
NEXT_PUBLIC_SITE_APEX=oricosmos.com
VITE_SITE_APEX=oricosmos.com

# ── 认证（本环境内所有 App 必须一致；可与 orasage 生产不同） ──
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token
JWT_COOKIE_DOMAIN=.oricosmos.com
COOKIE_DOMAIN=.oricosmos.com

# ── 公网 URL ─────────────────────────────────────────────────
APP_URL=https://oricosmos.com

AUTH_URL=https://auth.oricosmos.com
AUTH_INTERNAL_URL=http://127.0.0.1:3101

SHOP_URL=https://shop.oricosmos.com
SHOP_INTERNAL_URL=http://127.0.0.1:3102

BAZI_URL=https://bazi.oricosmos.com
BAZI_INTERNAL_URL=http://127.0.0.1:3110

ZIWEI_URL=https://ziwei.oricosmos.com
ZIWEI_INTERNAL_URL=http://127.0.0.1:3111

TAROT_URL=https://tarot.oricosmos.com
TAROT_INTERNAL_URL=http://127.0.0.1:3112

# CMS：公网 cms 子域重定向；管理入口 admin.oricosmos.com/cms
CMS_PUBLIC_URL=https://admin.oricosmos.com/cms
CMS_INTERNAL_URL=http://127.0.0.1:3120/cms

ADMIN_URL=https://admin.oricosmos.com

# ── 数据库（本机 PostgreSQL，勿连 orasage 生产库） ───────────
DATABASE_URL=postgresql://orasage:CHANGE_ME@127.0.0.1:5432/orasage_auth
# bazi/.env  → .../orasage_bazi
# tarot/.env → .../orasage_tarot
# cms/.env   → .../orasage_cms（PAYLOAD_SECRET 须另设，勿等于 JWT_SECRET）
REDIS_URL=redis://127.0.0.1:6379

# ── 支付 ─────────────────────────────────────────────────────
PAYMENT_MODE=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
