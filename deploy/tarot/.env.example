# tarot.orasage.com 部署环境变量
# 复制为 .env 后修改

# 部署模式：proxy（迁移）| native（自托管，需 TAROT_REPO_URL）
DEPLOY_MODE=proxy

# 迁移阶段上游地址 — 必填，请填入塔罗现有线上服务的真实地址
# （bazi 用 api1.lilyfunnlove.com，ziwei 用 api2.lilyfunnlove.com，
#   塔罗对应的真实上游地址尚未确认，请勿凭空填写，先向现有运营方确认）
TAROT_UPSTREAM_URL=

# Docker 镜像（proxy 模式默认本地构建）
TAROT_IMAGE=orasage-tarot-proxy:local

# 正式自托管时使用（git clone 地址，需 VPS 可访问）。
# 源码目前只在本机 /Users/mac/Downloads/tarot-app，尚未推送到可被
# VPS/CI 访问的 git 仓库；推送后（例如 GitHub abutang-droid/tarot-app）
# 再取消注释、填入真实地址。
# TAROT_REPO_URL=https://github.com/abutang-droid/tarot-app.git
# TAROT_REPO_BRANCH=main

# 自托管数据库（native 模式，塔罗现用 MySQL + Prisma）
# DATABASE_URL=mysql://tarot:changeme@tarot-db:3306/tarot

# 与 auth 服务共享
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token
JWT_COOKIE_DOMAIN=.orasage.com
AUTH_INTERNAL_URL=http://127.0.0.1:3101
