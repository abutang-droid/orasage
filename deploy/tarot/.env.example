# tarot.orasage.com 部署环境变量
# 复制为 .env 后修改

# 部署模式：proxy（迁移）| native（自托管，默认）
DEPLOY_MODE=native

# native 运行时：systemd | docker
NATIVE_RUNTIME=systemd

# 迁移阶段上游地址 — 仅 proxy 模式需要；native 模式可留空
TAROT_UPSTREAM_URL=

# Docker 镜像（proxy 模式默认本地构建）
TAROT_IMAGE=orasage-tarot-proxy:local

# 自托管源码仓库
TAROT_REPO_URL=https://github.com/abutang-droid/tarot-mind.git
TAROT_REPO_BRANCH=main

# 自托管数据库（native 模式，Prisma + MySQL）
# DATABASE_URL=mysql://tarot:changeme@127.0.0.1:3306/tarot

# 与 auth 服务共享
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token
JWT_COOKIE_DOMAIN=.orasage.com
AUTH_URL=https://auth.orasage.com
AUTH_INTERNAL_URL=http://127.0.0.1:3101
