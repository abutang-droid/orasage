[Unit]
Description=OraSage Ziwei Doushu (Next.js)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/orasage/ziwei
EnvironmentFile=-/opt/orasage/ziwei/.env
Environment=NODE_ENV=production
Environment=PORT=3111
Environment=HOSTNAME=127.0.0.1
ExecStart=/usr/local/bin/npm start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
