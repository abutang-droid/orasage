# 紫微斗数 ziwei 应用环境变量
# 复制为 /opt/orasage/ziwei/.env

NODE_ENV=production
PORT=3111
HOSTNAME=127.0.0.1

# 公网 URL（用于 canonical / OAuth redirect）
NEXT_PUBLIC_APP_URL=https://ziwei.orasage.com

# 认证集成
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token
AUTH_URL=https://auth.orasage.com

# 数据库（MySQL）
DATABASE_URL=mysql://user:pass@127.0.0.1:3306/ziwei

# AI 解读（Gemini）
GEMINI_API_KEY=

# 商城内网 API
SHOP_INTERNAL_URL=http://127.0.0.1:3102
