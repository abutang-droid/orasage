# ziwei.orasage.com 完全自托管环境变量
# 复制为 /opt/orasage/ziwei/.env 后修改

DEPLOY_MODE=native

# GitHub 源码（必填）
ZIWEI_REPO_URL=https://github.com/abutang-droid/ziwei.git
ZIWEI_REPO_BRANCH=main
# 私有仓库克隆令牌（可选）
# GITHUB_TOKEN=ghp_xxxxxxxx

# 应用
NODE_ENV=production
PORT=3111
HOSTNAME=0.0.0.0
NEXT_PUBLIC_APP_URL=https://ziwei.orasage.com

# MySQL
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=ziwei
MYSQL_USER=ziwei
MYSQL_PASSWORD=changeme
DATABASE_URL=mysql://ziwei:changeme@ziwei-db:3306/ziwei

# 认证（与 auth.orasage.com 共享）
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token
JWT_COOKIE_DOMAIN=.orasage.com
AUTH_URL=https://auth.orasage.com

# AI 解读
GEMINI_API_KEY=
