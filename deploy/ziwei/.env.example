# ziwei.orasage.com 部署环境变量
# 复制为 .env 后修改

# 部署模式：proxy（迁移）| native（自托管，需 ZIWEI_REPO_URL）
DEPLOY_MODE=proxy

# 迁移阶段上游地址（现有线上紫微服务）
ZIWEI_UPSTREAM_URL=https://api2.lilyfunnlove.com

# Docker 镜像（proxy 模式默认本地构建）
ZIWEI_IMAGE=orasage-ziwei-proxy:local

# 正式自托管时使用（git clone 地址，需 VPS 可访问）。
# 源码目前只在本机 /Users/mac/Downloads/ziwei-doushu，尚未推送到可被
# VPS/CI 访问的 git 仓库；推送后（例如 GitHub abutang-droid/ziwei-doushu）
# 再取消注释、填入真实地址。
# ZIWEI_REPO_URL=https://github.com/abutang-droid/ziwei-doushu.git
# ZIWEI_REPO_BRANCH=main

# 自托管 MySQL（native 模式）
# MYSQL_ROOT_PASSWORD=changeme
# MYSQL_DATABASE=ziwei
# MYSQL_USER=ziwei
# MYSQL_PASSWORD=changeme
# DATABASE_URL=mysql://ziwei:changeme@ziwei-db:3306/ziwei

# 与 auth 服务共享
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token
JWT_COOKIE_DOMAIN=.orasage.com
AUTH_INTERNAL_URL=http://127.0.0.1:3101
