# ziwei.orasage.com（ziwei-doushu）部署环境变量
# 复制为 .env 后修改

NODE_ENV=production
PORT=3111
NEXT_PUBLIC_SITE_URL=https://ziwei.orasage.com

# AI 解读（OpenAI 兼容协议，任选一家配置）
DEEPSEEK_API_KEY=
# 或 MANUS_API_KEY / MANUS_API_BASE / OPENAI_API_KEY / AI_MODEL

# 桥接 orasage 统一登录（与 auth-service 共享同一个 JWT_SECRET）。
# 不配置时该 App 保持完全匿名可用，不受影响。
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
AUTH_URL=https://auth.orasage.com
AUTH_INTERNAL_URL=http://127.0.0.1:3101
PARENT_AUTH_COOKIE_NAME=orasage_token
