# ziwei.orasage.com（ziwei-doushu）部署环境变量
# 复制为 .env 后修改

NODE_ENV=production
PORT=3111
NEXT_PUBLIC_SITE_URL=https://ziwei.orasage.com
NEXT_PUBLIC_CMS_URL=https://admin.orasage.com/cms
CMS_INTERNAL_URL=http://127.0.0.1:3120/cms

# AI 解读（OpenAI 兼容协议，任选一家配置）
DEEPSEEK_API_KEY=
# 或 MANUS_API_KEY / MANUS_API_BASE / OPENAI_API_KEY / AI_MODEL

# 桥接 orasage 统一登录（与 auth-service 共享同一个 JWT_SECRET）。
# 不配置时该 App 保持完全匿名可用，不受影响。
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
AUTH_URL=https://auth.orasage.com
AUTH_INTERNAL_URL=http://127.0.0.1:3101
PARENT_AUTH_COOKIE_NAME=orasage_token

# 51 万样本库（AI 解读参考，仅 VPS 本机路径，勿提交 Git）
# 解压后目录，见 deploy/download-ziwei-samples-on-vps.sh
ZIWEI_SAMPLES_DIR=/opt/orasage/data/ziwei-samples/ziwei-samples-toolkit
# 设为 false 可关闭样本库注入
# ZIWEI_SAMPLES_ENABLED=false
# 单主题 / 总上下文字符上限（默认 800 / 6000）
# ZIWEI_SAMPLES_MAX_TOPIC_CHARS=800
# ZIWEI_SAMPLES_MAX_CONTEXT_CHARS=6000
# SQLite 索引路径（build-sqlite-index.mjs 生成，冷启动更快）
# ZIWEI_SAMPLES_INDEX=/opt/orasage/data/ziwei-samples/ziwei-samples-toolkit/samples-index.sqlite
# 预览：默认直接用样本 overview；设为 true 才调用 LLM 轻润色
# ZIWEI_PREVIEW_LLM=false
# 古籍 RAG 注入（默认开启，设为 false 关闭）
# ZIWEI_CLASSICS_RAG=true
