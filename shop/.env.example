NODE_ENV=production
PORT=3102
HOSTNAME=127.0.0.1

JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_COOKIE_NAME=orasage_token

AUTH_URL=https://auth.orasage.com
AUTH_INTERNAL_URL=http://127.0.0.1:3101
SHOP_URL=https://shop.orasage.com

# 支付模式：mock（默认，开发/生产均用于风控审核与流程测试）| stripe（需同时配置 Stripe 密钥）
PAYMENT_MODE=mock

# 仅 PAYMENT_MODE=stripe 时生效
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# tarot 供养功德回调（支付成功后通知 tarot /api/internal/merit/offer）
TAROT_INTERNAL_URL=http://127.0.0.1:3112
TAROT_INTERNAL_SECRET=
