# tarot.orasage.com（tarot-mind）部署环境变量
# 复制为 .env 后修改

NODE_ENV=production
PORT=3112

# MySQL
DATABASE_URL="mysql://orasage:changeme@127.0.0.1:3306/tarot"

# 与 orasage 生态共享（auth-service / shop / main / ... 必须使用同一个值）。
# 同时用于签发本地访客 tarot_token 与验证父应用 orasage_token。
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"
AUTH_URL="https://auth.orasage.com"
PARENT_AUTH_COOKIE_NAME=orasage_token
NEXT_PUBLIC_APP_URL="https://tarot.orasage.com"

# 圣地 / 宗教数据（Payload CMS）
CMS_URL="https://cms.orasage.com"
NEXT_PUBLIC_CMS_URL="https://cms.orasage.com"
