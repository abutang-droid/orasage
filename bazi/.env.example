# bazi.orasage.com（bazi-calculator）部署环境变量
# 复制为 .env 后修改

NODE_ENV=production
PORT=3110

# MySQL
DATABASE_URL=mysql://orasage:changeme@127.0.0.1:3306/bazi_calculator

# 与 orasage 生态共享（auth-service / shop / main / ... 必须使用同一个值）
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
# 父应用统一登录 cookie 名（与 auth-service 的 JWT_COOKIE_NAME 一致）
PARENT_AUTH_COOKIE_NAME=orasage_token

# Manus OAuth（现有独立登录方式，与上面的 orasage 桥接登录并存，互不影响）
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# AI 解读
DEEPSEEK_API_KEY=
# 或 BUILT_IN_FORGE_API_URL / BUILT_IN_FORGE_API_KEY

# WordPress / WooCommerce（现有支付与用户报告中心集成，见 references/orasage-payment/）
WORDPRESS_URL=https://www.c2.pub
WP_WOO_KEY=
WP_WOO_SECRET=
