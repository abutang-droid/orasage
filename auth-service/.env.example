# 服务端口
PORT=3101

# 数据库
DATABASE_URL=postgres://orasage:password@localhost:5432/orasage_auth

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=30d

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3100,http://localhost:3110,http://localhost:3111,http://localhost:3112,https://orasage.com

# 域名（用于 Cookie Domain）
COOKIE_DOMAIN=.orasage.com

# 订单提醒 + 工单通知（消息中枢 #11 / #9）
# Telegram：@BotFather 创建 bot 取 token；chat id 可逗号分隔多个
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 邮件（Resend）：运营通知与用户工单回复共用；收件人可逗号分隔
RESEND_API_KEY=
ORDER_NOTIFY_EMAIL_TO=
ORDER_NOTIFY_EMAIL_FROM=OraSage <onboarding@resend.dev>
# 订单事件（默认 created,paid）
ORDER_NOTIFY_EVENTS=created,paid
