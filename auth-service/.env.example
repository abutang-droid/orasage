# 服务端口
PORT=3101

# 数据库
DATABASE_URL=postgres://orasage:password@localhost:5432/orasage_auth

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=30d

# CORS 允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3110,http://localhost:3111,http://localhost:3112

# 域名（用于 Cookie Domain）
COOKIE_DOMAIN=.orasage.com
